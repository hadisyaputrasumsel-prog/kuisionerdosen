                        </a>
                    </div>
                    <div class="contact-info">
                        <a href="mailto:info@uss.ac.id" class="contact-link text-decoration-none" aria-label="Email USS">
                            <i class="fas fa-envelope text-white" aria-hidden="true"></i>
                            <span class="text-white">info@uss.ac.id</span>
                        </a>
                    </div>
                </div>
            </div>

            <footer class="uss-footer__copyright text-center py-3"
                    role="contentinfo"
                    aria-label="Copyright notice"
                    itemscope itemtype="https://schema.org/CollegeOrUniversity">
                <div class="container">
